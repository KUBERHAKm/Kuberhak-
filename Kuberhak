<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>LEVA OFFICIAL HUB</title>
</head>
<body>
<script>
(function() {
    document.documentElement.innerHTML = "<html><head></head><body></body></html>";
    const style = document.createElement('style');
    style.innerHTML = `
        body { margin: 0; padding: 0; background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%); font-family: 'Segoe UI', sans-serif; display: flex; align-items: center; justify-content: center; height: 100vh; overflow: hidden; }
        .glass-card { background: rgba(255, 255, 255, 0.1); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); border: 1px solid rgba(255, 255, 255, 0.2); border-radius: 35px; padding: 25px; width: 90%; max-width: 550px; max-height: 85vh; text-align: center; color: white; box-shadow: 0 20px 50px rgba(0,0,0,0.3); display: flex; flex-direction: column; animation: fadeIn 0.5s ease; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
        .content-scroll { overflow-y: auto; text-align: left; flex-grow: 1; padding-right: 15px; margin: 15px 0; }
        .content-scroll::-webkit-scrollbar { width: 6px; }
        .content-scroll::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.3); border-radius: 10px; }
        h1 { font-size: 1.8rem; margin: 0; letter-spacing: 3px; color: #fff; text-shadow: 0 2px 10px rgba(0,0,0,0.2); }
        h2 { font-size: 1.2rem; color: #8EC5FC; margin: 25px 0 10px; border-bottom: 1px solid rgba(255,255,255,0.2); padding-bottom: 5px; }
        p { font-size: 0.9rem; line-height: 1.6; color: #e0e0e0; margin-bottom: 10px; }
        b { color: #fff; background: rgba(142, 197, 252, 0.3); padding: 2px 6px; border-radius: 5px; }
        code { display: block; background: rgba(0,0,0,0.4); padding: 12px; border-radius: 12px; font-family: 'Consolas', monospace; font-size: 0.8rem; color: #a5d6ff; margin: 10px 0; border-left: 3px solid #8EC5FC; }
        .btn { display: block; width: 100%; padding: 18px; border-radius: 20px; font-weight: bold; border: none; cursor: pointer; transition: 0.3s; font-size: 1rem; text-transform: uppercase; }
        .btn-blue { background: #8EC5FC; color: #1e3c72; box-shadow: 0 5px 15px rgba(142,197,252,0.4); }
        .btn-blue:hover { transform: scale(1.02); }
        .btn-outline { background: transparent; border: 2px solid #8EC5FC; color: #8EC5FC; margin-top: 15px; }
    `;
    document.head.appendChild(style);

    function renderHome() {
        document.body.innerHTML = "";
        const card = document.createElement('div');
        card.className = "glass-card";
        card.innerHTML = `
            <h1>KUBERHAK DEV HUB</h1>
            <p style="margin-top:10px; opacity:0.8;">Центральная база знаний и фишек</p>
            <div style="flex-grow:1; display:flex; flex-direction:column; justify-content:center; gap:15px;">
                <button class="btn btn-blue" id="tgLink">МОЙ TELEGRAM КАНАЛ</button>
                <button class="btn btn-outline" id="openBase">ОТКРЫТЬ БАЗУ ЗНАНИЙ</button>
            </div>
        `;
        document.body.appendChild(card);
        document.getElementById('tgLink').onclick = () => window.location.href = 'https://t.me/FudroidIp';
        document.getElementById('openBase').onclick = renderMenu;
    }

    function renderMenu() {
        document.body.innerHTML = "";
        const card = document.createElement('div');
        card.className = "glass-card";
        card.innerHTML = `
            <h1>БАЗА ЗНАНИЙ</h1>
            <div class="content-scroll">
                <h2>🤖 Нейросети (ИИ)</h2>
                <p>Для корректной работы <b>Gemini</b> и <b>ChatGPT</b> в РФ без лишних костылей используй Частный DNS: <b>xbox-dns.ru</b>. Если нужно ускорить генерацию кода, включай <b>TLS Tunnel</b> через серверы Польши.</p>
                <p><i>Совет по промптам:</i> Всегда уточняй детали. Например: "Напиши код на JS для плавного появления кнопки при скролле".</p>

                <h2>🚫 Реклама и Трафик</h2>
                <p>Чтобы убрать баннеры в приложениях и браузере, пропиши системный DNS: <b>dns.adguard.com</b>. Это блокирует рекламу на уровне запросов, что экономит заряд батареи и твои нервы.</p>

                <h2>⚡ Оптимизация Пинга</h2>
                <p>Если лагает Roblox или другие игры, попробуй <b>1.1.1.1</b> или <b>one.one.one.one</b>. Этот DNS от Cloudflare сокращает путь пакетов до игровых серверов, снижая задержку (пинг).</p>

                <h2>📏 Настройки Android</h2>
                <p>Зайди в "Настройки разработчика" -> "Минимальная ширина" (DPI). Увеличивая это число, ты уменьшаешь масштаб интерфейса, что полезно для работы с кодом и обзора в играх.</p>

                <h2>💻 Обучение JavaScript</h2>
                <p>Основы создания логики:</p>
                <b>Переменные:</b>
                <code>let speed = 100; // Можно менять\nconst name = "Leva"; // Нельзя менять</code>
                <b>Функции:</b>
                <code>function welcome() {\n  alert("Добро пожаловать!");\n}</code>
                <p>Функции позволяют выполнять блок кода только тогда, когда это нужно (например, при клике на кнопку).</p>
            </div>
            <button class="btn btn-outline" id="goBack">НАЗАД В МЕНЮ</button>
        `;
        document.body.appendChild(card);
        document.getElementById('goBack').onclick = renderHome;
    }
    renderHome();
})();
</script>
</body>
</html>


